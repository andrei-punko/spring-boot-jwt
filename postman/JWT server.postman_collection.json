  "item": [
    {
      "name": "Get admin Auth Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();\r",
              "pm.collectionVariables.set(\"admin_access_token\", jsonData.access_token);\r",
              "pm.collectionVariables.set(\"admin_refresh_token\", jsonData.refresh_token);\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "basic",
          "basic": [
            {
              "key": "password",
              "value": "{{secret}}",
              "type": "string"
            },
            {
              "key": "username",
              "value": "{{client}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "url": {
          "raw": "localhost:9090/oauth/token?grant_type=password&username={{admin_username}}&password={{admin_password}}",
          "host": [
            "localhost"
          ],
          "port": "9090",
          "path": [
            "oauth",
            "token"
          ],
          "query": [
            {
              "key": "grant_type",
              "value": "password"
            },
            {
              "key": "username",
              "value": "{{admin_username}}"
            },
            {
              "key": "password",
              "value": "{{admin_password}}"
            }
          ]
        }
      },
      "response": []
    },
